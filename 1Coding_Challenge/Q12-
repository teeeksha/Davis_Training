#Question 12: Check whether a person is eligible to vote.
#Input: Enter age
#Output: Eligible / Not Eligible
# Using function + boolean return

def is_eligible(age):
    return age >= 18

age = int(input("Enter your age: "))

if is_eligible(age):
    print("Eligible to vote")
else:
    print("Not eligible to vote")
