#Question 14: Print all even numbers between 1 to N.
#Input: Enter N
#Output: Even numbers list
# Storing in list

n = int(input("Enter N: "))

even_numbers = []

for i in range(1, n + 1):
    if i % 2 == 0:
        even_numbers.append(i)

print("Even numbers:", even_numbers)
