#Question 17: Check whether a person is eligible to vote.
#Input: Enter age
#Output: Eligible / Not Eligible
# Using try-except

try:
    age = int(input("Enter age: "))
    if age >= 18:
        print("Eligible")
    else:
        print("Not Eligible")
except:
    print("Invalid input")
