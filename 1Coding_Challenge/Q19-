#Question 19: Print all even numbers between 1 to N.
#Input: Enter N
#Output: Even numbers list
# Using list comprehension

n = int(input("Enter N: "))

even_numbers = [i for i in range(1, n + 1) if i % 2 == 0]

print("Even numbers:", even_numbers)
