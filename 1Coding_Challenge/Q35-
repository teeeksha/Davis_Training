#Question 35: Create a function to calculate simple interest.
#Input: Enter P, R, T
#Output: Simple Interest
def simple_interest():
    p = float(input("Enter P: "))
    r = float(input("Enter R: "))
    t = float(input("Enter T: "))

    si = (p * r * t) / 100
    print("SI:", si)

simple_interest()
