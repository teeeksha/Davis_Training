#Question 4:- Print all even numbers between 1 to N
#Input :- Enter N
# Output:- Even Number List

n = int(input("Enter value of N: "))

print("Even numbers are:")
for number in range(1, n + 1):
    if number % 2 == 0:
        print(number, end=" ")
