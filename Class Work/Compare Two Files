
Find lines that are present in file1 but not in file2.
     # Compare Two Files
# Find lines present in file1.txt but not in file2.txt

with open("file1.txt", "r") as f1, open("file2.txt", "r") as f2:
    lines1 = f1.readlines()
    lines2 = set(f2.readlines())   # use set for fast lookup

# write result to output file
with open("output.txt", "w") as out:
    for line in lines1:
        if line not in lines2:
            out.write(line)

print("Comparison done. Unique lines saved in output.txt")
