#Copy contents of one file into another.
# Algorithm :- Open source file in read mode (r)
               Open destination file in write mode (w)
               Read content from source file
               Write that content into destination file
               Close both files

# open source file
src = open("file1.txt", "r")

# open destination file
dest = open("file2.txt", "w")

# read content
data = src.read()

# write into another file
dest.write(data)

# close files 
src.close()
dest.close()

print("File copied successfully")
