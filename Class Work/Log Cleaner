import requests

url = "https://raw.githubusercontent.com/teeeksha/Davis_Training/refs/heads/main/Class%20Work/logs.txt"

lines = requests.get(url).text.split("\n")

unique_logs = set(lines)

error_logs = []
count = 0

for log in unique_logs:
    if log == "":
        continue

    if "ERROR" in log:
        error_logs.append(log)
        count += 1

print("ERROR Logs:")
for log in error_logs:
    print(log)

print("\nTotal ERROR logs:", count)
