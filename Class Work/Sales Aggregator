import requests

url = "https://raw.githubusercontent.com/teeeksha/Davis_Training/refs/heads/main/Class%20Work/Sales.txt"

lines = requests.get(url).text.split("\n")

category_sales = {}
max_sales = 0
top_product = ""

for line in lines:
    if line == "" or "product" in line:
        continue

    parts = line.split(",")

    try:
        product = parts[0]
        category = parts[1]
        price = int(parts[2])
        quantity = int(parts[3])

        sales = price * quantity

        if category in category_sales:
            category_sales[category] += sales
        else:
            category_sales[category] = sales

        if sales > max_sales:
            max_sales = sales
            top_product = product

    except:
        print("Invalid data:", line)

print("Sales per Category:")
for cat, total in category_sales.items():
    print(cat, "->", total)

print("\nTop Selling Product:", top_product, "with sales", max_sales)
