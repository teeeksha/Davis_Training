import requests

url = "https://raw.githubusercontent.com/teeeksha/Davis_Training/refs/heads/main/Class%20Work/students.txt"

lines = requests.get(url).text.split("\n")

topper = ""
max_percentage = 0

for line in lines:
    if line == "":
        continue

    parts = line.split(",")

    try:
        name = parts[1]
        m1 = int(parts[2])
        m2 = int(parts[3])
        m3 = int(parts[4])

        total = m1 + m2 + m3
        percentage = total / 3

        # Grade
        if percentage >= 90:
            grade = "A"
        elif percentage >= 75:
            grade = "B"
        elif percentage >= 50:
            grade = "C"
        else:
            grade = "Fail"

        print(name, "->", percentage, "->", grade)

        # Topper
        if percentage > max_percentage:
            max_percentage = percentage
            topper = name

    except:
        print("Invalid data:", line)

print("\nTopper:", topper, max_percentage)
