#program for writing data into the file
#opening file for write operation
Filev = open("firstfile.txt", "w")
#write twenty  sentence into file
print("Enter 20 sentences:")
for x in range(20):
    #input data from user 
    sentence = input()
#writing sentence into the file
    Filev.write(sentence + "\n")
print("****************************")
print("Data Successfully written")
#closing the file 
Filev.close()
