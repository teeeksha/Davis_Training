# Function to check prime
def is_prime(n):
    if n <= 1:
        return False
    
    # Check divisibility
    for i in range(2, n):
        if n % i == 0:
            return False
    
    return True

# Example Input
num = 7

if is_prime(num):
    print("Prime")
else:
    print("Not Prime")
#Output:-Prime
