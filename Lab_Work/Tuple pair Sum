Question 10: Tuple Pair Sum
#Problem Statement:Find all pairs in a tuple whose sum equals a given value.
t = (2, 4, 3, 5, 7, 8)
target = 7

pairs = []

for i in range(len(t)):
    for j in range(i + 1, len(t)):
        if t[i] + t[j] == target:
            pairs.append((t[i], t[j]))

print(pairs)
     
